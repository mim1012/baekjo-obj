# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local logs (build/install output — not part of the project)
*.log

# editor / IDE local caches (team uses different IDEs: Antigravity, Claude Code, Codex, VS Code, JetBrains)
# each tool's local state stays local — never commit it. Add your IDE's folder here if it creates one.
.vscode/
.idea/
.codex-home/
.omc/

# 고객사 원본 자료 (6.9GB — 웹 가공 전 소스. 커밋 금지, 가공본만 public/에 커밋)
/백조오브제/
cookies.txt

# playwright (골든플로우 E2E 산출물)
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
.gstack/

# 에이전트 세션 로컬 상태·검증 산출물 (레포 루트 오염 방지 — 증빙은 docs/evidence/ 또는 스크래치패드에)
.claude/
.mcp.json
.gjc/
.ralplan-tmp/
RESEARCH/
.ultragoal-brief-*.md
AGENTS.md.resolved
/g[0-9][0-9][0-9]-*
/goal-snapshot-*.json
/quality-gate-*.json
/gate3-*.png
/__*.mjs
/tests/golden/__*.spec.ts
