# Auth.js (소셜 로그인) — 값 채우면 로컬에서 동작. 실값은 .env.local에만.
AUTH_SECRET=            # npx auth secret 또는 openssl rand -base64 32
AUTH_KAKAO_ID=          # 카카오 디벨로퍼스 > 앱 > REST API 키
AUTH_KAKAO_SECRET=      # 카카오 로그인 > 보안 > Client Secret
AUTH_NAVER_ID=          # 네이버 개발자센터 > 애플리케이션 > Client ID
AUTH_NAVER_SECRET=      # Client Secret
NEXT_PUBLIC_SOCIAL_LOGIN=1   # 1이면 로그인 화면 소셜 버튼 활성화 (키 없인 켜지 말 것)

# Supabase (베타 회원 DB) — 서버 전용. 절대 NEXT_PUBLIC_ 붙이지 말 것.
SUPABASE_URL=           # 대시보드 > Settings > API > Project URL (https://xxxx.supabase.co)
SUPABASE_SECRET_KEY=    # sb_secret_... — 서버(라우트 핸들러)에서만 사용
SUPABASE_PUBLISHABLE_KEY=   # sb_publishable_... — 현재 미사용(향후 클라이언트 직접 접근용)
SUPABASE_ACCESS_TOKEN=  # sbp_... 개인 액세스 토큰 — 마이그레이션 실행용(로컬 전용, 배포에 불필요)

# 이메일 발송(Gmail SMTP) — 서버 전용. 이메일 인증·비밀번호 재설정 메일 발송에 사용.
SMTP_GMAIL_USER=        # 발신용 구글 계정 이메일
SMTP_GMAIL_APP_PASSWORD=    # 구글 계정 > 보안 > 2단계 인증 활성화 후 발급되는 "앱 비밀번호"(일반 로그인 비밀번호 아님)

# 인증/재설정 메일 링크의 base URL. 요청 Host 헤더(X-Forwarded-Host 포함)는 조작 가능해
# 그걸로 링크를 만들면 공격자 도메인이 메일에 실릴 수 있다 — 프로덕션 배포에서는 반드시 설정할 것.
# 미설정 시에는 request.nextUrl.origin으로 폴백한다(로컬 dev 전용, 배포에서 의존 금지).
APP_BASE_URL=            # 예: https://baekjo-obj.vercel.app (끝 슬래시 없이)

# 토스페이먼츠 v2 결제위젯 — 시크릿키는 서버 전용(절대 NEXT_PUBLIC_ 붙이지 말 것), 클라이언트키만 공개.
TOSS_SECRET_KEY=         # 테스트: test_gsk_docs_OaPz8L5KdmQXkzRz3y47BMw6 (라이브 키는 계약 승인 후 교체)
NEXT_PUBLIC_TOSS_CLIENT_KEY=   # 테스트: test_gck_docs_Ovk5rk1EwkEbP0W43n07xlzm

# 스마트택배(Sweet Tracker) 배송조회 API — 서버 전용(절대 NEXT_PUBLIC_ 붙이지 말 것).
# FREE 플랜=100건/월, 동일 송장 1일 10회 제한. 미설정 시 기존 택배사 딥링크(@/lib/carriers)로 폴백.
SWEETTRACKER_API_KEY=
